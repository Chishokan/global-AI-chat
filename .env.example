# Anthropic Claude API キー（サーバー専用。クライアントには絶対に出さない）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 任意: チャット応答に使うモデルID（未設定時はコード内の既定値を使用）
# 最新のモデルIDは Anthropic コンソールで確認してください。
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6

# 任意: ログのカテゴリ/言語分類に使う軽量モデルID（未設定時はコード内の既定値）
# ANTHROPIC_CLASSIFY_MODEL=claude-haiku-4-5-20251001

# --- 会話ログ（Google スプレッドシート / GAS Web App）。設定すると有効化 ---
# 設定手順は docs/SHEETS_LOGGING.md を参照。両方そろうとログ保存がON。
# SHEETS_WEBAPP_URL=https://script.google.com/macros/s/xxxxx/exec
# SHEETS_WEBAPP_TOKEN=replace-with-a-long-random-string

# --- 以下は Phase 2 のDB/レポートで使用（今は不要） ---
# PostgreSQL 接続文字列
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Cron エンドポイント保護用トークン
# CRON_SECRET=replace-with-a-long-random-string
